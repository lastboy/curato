{
  "version": 1,

  // Optional: inherit from a shared company config (public GitHub repo only).
  // Local keys override remote keys. Arrays are unioned (you can add but not remove).
  // "extends": "github:mycompany/claude-setup",

  // MCP servers to register for this team.
  // scope "project" → written to .mcp.json (relative paths work, good for repo-local servers)
  // scope "user"    → written to ~/.claude/settings.json + ~/.claude.json
  "mcpServers": {
    "company-tools": {
      "command": "/usr/local/bin/company-mcp",
      "scope": "user"
    },
    "local-dev-server": {
      "command": "node",
      "args": ["./tools/mcp/index.js"],
      "scope": "project"
    }
  },

  // Plugins to install (always user-scoped, skipped if already installed).
  // Find available plugin names with: claude plugin list --available --json
  "plugins": [
    "code-review",
    "commit-commands",
    "pr-review-toolkit"
  ],

  // CLAUDE.md content to scaffold.
  "claudeMd": {
    // Project CLAUDE.md — created only if missing.
    "project": {
      "mode": "create-if-missing",
      "content": "# Project\n\n## Stack\n\nDescribe your stack here.\n\n## Standards\n\nDescribe your coding standards here.\n"
    },

    // User CLAUDE.md (~/.claude/CLAUDE.md) — appends a section if it's not already present.
    // Use this for company-wide rules that apply across all projects.
    "user": {
      "mode": "append-if-missing-section",
      "section": "## Company Standards",
      "content": "## Company Standards\n\nAlways follow the company style guide.\nLink to internal docs here.\n"
    }
  }
}
