{
  "name": "@curato/mcp-server",
  "version": "0.1.0",
  "description": "Curato MCP server — environment scanning, repair, and smoke-testing",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "node --import tsx/esm --test 'src/__tests__/**/*.test.ts'",
    "test:unit": "node --import tsx/esm --test 'src/__tests__/scanner/**/*.test.ts' 'src/__tests__/patcher/**/*.test.ts' 'src/__tests__/tools/**/*.test.ts'",
    "test:integration": "node --import tsx/esm --test 'src/__tests__/integration/**/*.test.ts'"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
