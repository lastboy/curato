{
  "name": "curato",
  "version": "0.1.0",
  "description": "Claude Code environment scanning, repair, and smoke-testing toolkit",
  "type": "module",
  "private": true,
  "workspaces": [
    "mcp-server"
  ],
  "scripts": {
    "build": "npm run build --workspace=mcp-server",
    "test": "npm run test --workspace=mcp-server",
    "test:unit": "npm run test:unit --workspace=mcp-server",
    "test:integration": "npm run test:integration --workspace=mcp-server",
    "start": "npm run start --workspace=mcp-server",
    "install:curato": "bash scripts/install.sh"
  }
}
